      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='diabetic_data (diabetic_data)' name='federated.1sy3sqc039ugfo14sqmfx1o1ju4y' />
          </datasources>
          <datasource-dependencies datasource='federated.1sy3sqc039ugfo14sqmfx1o1ju4y'>
            <column caption='Readmission Flag' datatype='integer' name='[Calculation_153122442427219968]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [readmitted] = &quot;&lt;30&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Readmission Rate' datatype='real' name='[Calculation_153122442427428865]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_153122442427219968])' />
            </column>
            <column caption='Readmitted' datatype='string' name='[readmitted]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;&lt;30&quot;' value='&lt;30 days' />
                <alias key='&quot;&gt;30&quot;' value='&gt;30 days' />
              </aliases>
            </column>
            <column-instance column='[Calculation_153122442427428865]' derivation='User' name='[usr:Calculation_153122442427428865:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.1sy3sqc039ugfo14sqmfx1o1ju4y].[usr:Calculation_153122442427428865:qk]' value='p0.00%' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#d2d2d2' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
